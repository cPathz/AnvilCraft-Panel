{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnvilCraft Panel",
  "version": "0.1.4",
  "identifier": "AnvilCraftPanel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "AnvilCraft Panel v0.1.4 (Beta)",
        "width": 1024,
        "height": 660,
        "minWidth": 1024,
        "minHeight": 660
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; connect-src 'self' https: http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Luis Macias (cPathz)",
    "copyright": "© 2025 AnvilCraft Panel",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}