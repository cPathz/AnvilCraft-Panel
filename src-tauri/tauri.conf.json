{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "temp_app",
  "version": "0.1.0",
  "identifier": "com.luism.temp_app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "AnvilCraft Panel v0.1.0 Copia de Evaluación",
        "width": 1024,
        "height": 660,
        "minWidth": 1024,
        "minHeight": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}